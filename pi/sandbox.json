{
  "filesystem": {
    "allowGitConfig": true,
    "allowRead": [
      "~/devs",
      "~/.npmrc",
      "~/.nvm",
      "~/.ssh",
      "~/.gitignore_global",
      "~/.gitconfig",
      "~/.config",
      "~/.local",
      "~/.pi",
      "~/Library/Keychains",
      "~/Downloads",
      "/private/tmp"
    ]
  },
  "network": {
    "allowedDomains": [
      "nodejs.org",
      "github.com",
      "*.github.com",
      "*.githubusercontent.com",
      "registry.npmjs.org"
    ],
    "deniedDomains": [],
    "allowUnixSockets": [
      "/private/tmp/tmux-502"
    ]
  }
}
