{
  "filesystem": {
    "allowGitConfig": true,
    "allowRead": [
      "~/devs",
      "~/bin",
      "~/.copilot",
      "~/.npmrc",
      "~/.nvm",
      "~/.ssh",
      "~/.gitignore_global",
      "~/.gitconfig",
      "~/.config",
      "~/.local",
      "~/.pi",
      "~/.npm",
      "~/.npmrc",
      "~/Library/Caches",
      "~/Library/Keychains",
      "~/Library/pnpm",
      "~/Downloads",
      "/tmp",
      "/private/tmp"
    ],
    "allowWrite": [
      ".",
      "~/.npm",
      "~/.copilot",
      "~/.config",
      "~/Library/Caches",
      "/tmp",
      "/private/tmp"
    ]
  },
  "network": {
    "allowLocalBinding": true,
    "allowedDomains": [
      "nodejs.org",
      "github.com",
      "*.github.com",
      "*.githubusercontent.com",
      "api.business.githubcopilot.com",
      "*.githubcopilot.com",
      "npmjs.com",
      "registry.npmjs.org",
      "unpkg.com",
      "api.tailor.tech",
      "base-ui.com"
    ],
    "allowMachLookup": [
      "com.apple.SystemConfiguration.configd",
      "com.apple.dnssd.service",
      "com.apple.trustd.agent"
    ],
    "allowUnixSockets": [
      "/private/tmp/tmux-502",
      "/var/run/mDNSResponder"
    ],
    "deniedDomains": []
  }
}
