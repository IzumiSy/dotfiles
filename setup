#!/usr/bin/env bash
set -Ceu

# Resolve paths relative to this script, not the current directory.
ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Commands required for setup.
TOOLS=(
  "git"
  "curl"
)

# source:destination pairs for symlinks.
LINKS=(
  "pi/settings.json:$HOME/.pi/agent/settings.json"
  "pi/AGENTS.md:$HOME/.pi/agent/AGENTS.md"
  "pi/sandbox.json:$HOME/.pi/agent/sandbox.json"
  "pi/command-gate/global.json:$HOME/.pi/agent/command-gate/global.json"
  "nvim:$HOME/.config/nvim"
  "_vimrc:$HOME/.vimrc"
  "_tmux.conf:$HOME/.tmux.conf"
  "_bashrc:$HOME/.bashrc"
  "_starship.toml:$HOME/.starship.toml"
  "_alacritty.toml:$HOME/.alacritty.toml"
  "herdr/config.toml:$HOME/.config/herdr/config.toml"
  "git/_gitconfig:$HOME/.gitconfig"
  "git/_gitignore_global:$HOME/.gitignore_global"
  "git/_tigrc:$HOME/.tigrc"
)

# Fail fast if required commands are missing.
check_tools() {
  for cmd in "${TOOLS[@]}"; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
      echo "$cmd is required to be installed."
      exit 1
    fi
  done
}

# Create parent directories needed before linking.
prepare() {
  local entry dst

  for entry in "${LINKS[@]}"; do
    dst="${entry#*:}"
    mkdir -p "$(dirname "$dst")"
  done
}

# Clean up the old broken layout where ~/.config/nvim was created as a
# directory and the repo link ended up inside it as ~/.config/nvim/nvim.
cleanup_legacy_nested_link() {
  local src="$1"
  local dst="$2"
  local target="$3"
  local legacy="$dst/$(basename "$src")"

  if [[ -d "$dst" ]] && [[ ! -L "$dst" ]] && [[ -L "$legacy" ]] && [[ "$(readlink "$legacy")" == "$target" ]]; then
    if [[ -z "$(find "$dst" -mindepth 1 -maxdepth 1 ! -path "$legacy" -print -quit)" ]]; then
      rm -f "$legacy"
      rmdir "$dst"
      echo "fixed $legacy"
    fi
  fi
}

# Create or replace symlinks.
install_links() {
  prepare

  for entry in "${LINKS[@]}"; do
    src="${entry%%:*}"
    dst="${entry#*:}"
    target="$ROOT_DIR/$src"

    cleanup_legacy_nested_link "$src" "$dst" "$target"

    if [[ -L "$dst" ]] && [[ "$(readlink "$dst")" == "$target" ]]; then
      echo "skip $dst"
      continue
    fi

    if [[ -d "$dst" ]] && [[ ! -L "$dst" ]]; then
      echo "error: $dst already exists as a directory; move it away and re-run." >&2
      exit 1
    fi

    ln -snvf "$target" "$dst"
  done
}

# Remove only the symlinks managed by this script.
uninstall_links() {
  for entry in "${LINKS[@]}"; do
    src="${entry%%:*}"
    dst="${entry#*:}"
    target="$ROOT_DIR/$src"

    if [[ -L "$dst" ]] && [[ "$(readlink "$dst")" == "$target" ]]; then
      rm -f "$dst"
      echo "removed $dst"
    else
      echo "skip $dst"
    fi
  done
}

# Default action is install.
case "${1:-install}" in
  install)
    check_tools
    install_links
    echo
    echo "To apply the changes, run: exec \"$SHELL\" --login"
    ;;
  uninstall)
    uninstall_links
    ;;
  *)
    echo "Usage: $0 [install|uninstall]"
    exit 1
    ;;
esac
